From fadd8482d8e37f8ff1a61a8d8060e83cec744222 Mon Sep 17 00:00:00 2001
From: Michael Forney <mforney@mforney.org>
Date: Thu, 4 Jun 2020 21:44:26 -0700
Subject: [PATCH] pax: Use memcpy to set TMAGIC and TVERSION to avoid warning

---
 bin/pax/tar.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/bin/pax/tar.c b/bin/pax/tar.c
index 1c5065ce655..ac6f3c60d94 100644
--- a/bin/pax/tar.c
+++ b/bin/pax/tar.c
@@ -1056,8 +1056,8 @@ wr_xheader(char *fname, HD_USTAR *fhd, struct xheader *xhdr)
 	memset(hdblk, 0, sizeof(hdblk));
 	hd = (HD_USTAR *)hdblk;
 	hd->typeflag = XHDRTYPE;
-	strncpy(hd->magic, TMAGIC, TMAGLEN);
-	strncpy(hd->version, TVERSION, TVERSLEN);
+	memcpy(hd->magic, TMAGIC, TMAGLEN);
+	memcpy(hd->version, TVERSION, TVERSLEN);
 	if (ul_oct(size, hd->size, sizeof(hd->size), 3))
 		goto out;
 
@@ -1276,8 +1276,8 @@ wr_ustar_or_pax(ARCHD *arcn, int ustar)
 		break;
 	}
 
-	strncpy(hd->magic, TMAGIC, TMAGLEN);
-	strncpy(hd->version, TVERSION, TVERSLEN);
+	memcpy(hd->magic, TMAGIC, TMAGLEN);
+	memcpy(hd->version, TVERSION, TVERSLEN);
 
 	/*
 	 * set the remaining fields. Some versions want all 16 bits of mode
-- 
