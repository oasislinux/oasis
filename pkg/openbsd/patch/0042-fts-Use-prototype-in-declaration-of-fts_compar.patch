From 5b997ce94b67bfd5c3f1a34c33fb14b11a8b5c81 Mon Sep 17 00:00:00 2001
From: Michael Forney <mforney@mforney.org>
Date: Thu, 2 Apr 2026 17:17:27 -0700
Subject: [PATCH] fts: Use prototype in declaration of fts_compar

In C23, empty parenthesis indications a function taking no arguments.
---
 include/fts.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/fts.h b/include/fts.h
index a5b3aff91e7..ef25e88d298 100644
--- a/include/fts.h
+++ b/include/fts.h
@@ -46,7 +46,7 @@ typedef struct {
 	int fts_rfd;			/* fd for root */
 	size_t fts_pathlen;		/* sizeof(path) */
 	int fts_nitems;			/* elements in the sort array */
-	int (*fts_compar)();		/* compare function */
+	int (*fts_compar)(const void *, const void *); /* compare function */
 
 #define	FTS_COMFOLLOW	0x0001		/* follow command line symlinks */
 #define	FTS_LOGICAL	0x0002		/* logical walk */
-- 
2.49.0

