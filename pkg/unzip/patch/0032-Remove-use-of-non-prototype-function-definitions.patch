 COPTIONS = $(COPTIONS) ERRORREXX NOERRORCONSOLE MEMSIZE=HUGE $(CLIST) $(CXREF)
 COPTIONS = $(COPTIONS) $(CSTACK) STRICT UNSCHAR NOICONS
